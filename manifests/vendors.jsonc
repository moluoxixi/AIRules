{
  // 所有第三方 skill 来源都先聚合到 ~/.moluoxixi/vendors，
  // 再按 link 规则统一暴露到 ~/.moluoxixi/skills。
  "version": 1,
  "vendors": {
    "superpowers": {
      "description": "底层工作流基线，提供 brainstorming、TDD、verification 等流程能力。",
      "repo": "https://github.com/obra/superpowers.git",
      "cloneDir": "vendors/superpowers",
      "links": [
        {
          "source": "skills",
          "target": "skills/superpowers",
          "description": "把 superpowers 整个 skills 目录作为命名空间入口暴露出去。"
        }
      ]
    },
    "anthropicSkills": {
      "description": "补充前端设计与 Web UI 测试能力。",
      "repo": "https://github.com/anthropics/skills.git",
      "cloneDir": "vendors/anthropic-skills",
      "links": [
        {
          "source": "skills/frontend-design",
          "target": "skills/frontend-design",
          "description": "高质量前端视觉与界面设计。"
        },
        {
          "source": "skills/webapp-testing",
          "target": "skills/webapp-testing",
          "description": "用 Playwright 验证本地 Web 应用。"
        }
      ]
    },
    "vercelSkills": {
      "description": "补充 Next.js 生态相关技能。",
      "repo": "https://github.com/vercel/next.js.git",
      "cloneDir": "vendors/vercel-skills",
      "links": [
        {
          "source": ".agents/skills/update-docs",
          "target": "skills/update-docs",
          "description": "更新 Next.js 文档与说明。"
        },
        {
          "source": ".claude-plugin/plugins/cache-components/skills/cache-components",
          "target": "skills/cache-components",
          "description": "Next.js Cache Components / PPR 实践。"
        }
      ]
    },
    "vercelLabsSkills": {
      "description": "补充技能发现与安装辅助能力。",
      "repo": "https://github.com/vercel-labs/skills.git",
      "cloneDir": "vendors/vercel-labs-skills",
      "links": [
        {
          "source": "skills/find-skills",
          "target": "skills/find-skills",
          "description": "帮助查找可安装的技能。"
        }
      ]
    },
    "geminiSkills": {
      "description": "复用 Gemini CLI 仓库里的通用工程技能。",
      "repo": "https://github.com/google-gemini/gemini-cli.git",
      "cloneDir": "vendors/gemini-skills",
      "links": [
        {
          "source": ".gemini/skills/code-reviewer",
          "target": "skills/code-reviewer",
          "description": "代码审查与风险检查。"
        },
        {
          "source": ".gemini/skills/pr-creator",
          "target": "skills/pr-creator",
          "description": "按仓库模板生成 PR。"
        }
      ]
    },
    "reactSkills": {
      "description": "补充修 lint、修格式、过 CI 的辅助技能。",
      "repo": "https://github.com/facebook/react.git",
      "cloneDir": "vendors/react-skills",
      "links": [
        {
          "source": ".claude/skills/fix",
          "target": "skills/fix",
          "description": "修复 lint、格式和常见构建问题。"
        }
      ]
    },
    "awesomeLlmApps": {
      "description": "补充通用全栈开发技能。",
      "repo": "https://github.com/Shubhamsaboo/awesome-llm-apps.git",
