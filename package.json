{
  "name": "moluoxixi-ai-rules",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Personal AI workflow distribution built on top of superpowers.",
  "license": "MIT",
  "repository": "https://github.com/moluoxixi/AIRules",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint --fix",
    "setup": "tsx scripts/host-setup.ts",
    "rules:install": "git pull && npm install && tsx scripts/host-setup.ts",
    "pretest": "npx tsx scripts/sync-vendors.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{vue,jsx,tsx,js,ts}": [
      "eslint --fix"
    ]
  }
}
